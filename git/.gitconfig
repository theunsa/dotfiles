[user]
	name = Theuns Alberts
	email = theunsa@gmail.com
[core]
	editor = nvim
[alias]
	st = status -sb
	c = commit
	cm = commit -m
	ca = commit --amend
	cam = commit -a -m
	co = checkout
	sw = switch
	br = branch
	lg = log --oneline --graph --decorate
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
